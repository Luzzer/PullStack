{
  "name": "pullstack",
  "version": "0.1.0",
  "description": "GitHub PR collaboration-risk analyzer for AI-assisted coding teams. Detects scope drift, risky shared-contract changes, missing tests, PR overlap and dangerous merge ordering.",
  "type": "module",
  "bin": {
    "pullstack": "dist/cli.js"
  },
  "main": "dist/analyzer/index.js",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    ".pullstack.example.yml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analyze": "tsx src/cli.ts analyze",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "github",
    "pull-request",
    "code-review",
    "merge-risk",
    "ai-coding",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luzzer/PullStack.git"
  },
  "bugs": {
    "url": "https://github.com/Luzzer/PullStack/issues"
  },
  "homepage": "https://github.com/Luzzer/PullStack#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "minimatch": "^9.0.5",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
